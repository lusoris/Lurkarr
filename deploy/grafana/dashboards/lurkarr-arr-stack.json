  "schemaVersion": 39,
  "tags": ["lurkarr", "arr"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(lurkarr_arr_instance_up, app_type)",
        "includeAll": true,
        "multi": true,
        "name": "app_type",
        "query": "label_values(lurkarr_arr_instance_up, app_type)",
        "refresh": 2,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(lurkarr_arr_instance_up{app_type=~\"$app_type\"}, instance)",
        "includeAll": true,
        "multi": true,
        "name": "instance",
        "query": "label_values(lurkarr_arr_instance_up{app_type=~\"$app_type\"}, instance)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Lurkarr — Arr Stack Overview",
  "uid": "lurkarr-arr-stack"
}
