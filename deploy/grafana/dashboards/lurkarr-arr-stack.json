{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview", "url": "/d/lurkarr-overview", "type": "link", "icon": "apps" },
    { "title": "Notifications", "url": "/d/lurkarr-notifications", "type": "link", "icon": "bell" },
    { "title": "System", "url": "/d/lurkarr-system", "type": "link", "icon": "cog" }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Instance Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Instance Status",
      "targets": [
        {
          "expr": "lurkarr_arr_instance_up{app_type=~\"$app_type\", instance=~\"$instance\"}",
          "legendFormat": "{{app_type}} / {{instance}} ({{version}})"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 7 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Health Warnings",
      "targets": [
        {
          "expr": "sum(lurkarr_arr_health_issues{app_type=~\"$app_type\", instance=~\"$instance\", type=\"warning\"}) by (app_type, instance)",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 7 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Health Errors",
      "targets": [
        {
          "expr": "sum(lurkarr_arr_health_issues{app_type=~\"$app_type\", instance=~\"$instance\", type=\"error\"}) by (app_type, instance)",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 7 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Health Notices",
      "targets": [
        {
          "expr": "sum(lurkarr_arr_health_issues{app_type=~\"$app_type\", instance=~\"$instance\", type=\"notice\"}) by (app_type, instance)",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 101,
      "title": "Download Queues",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Queue Size Over Time",
      "targets": [
        {
          "expr": "lurkarr_arr_queue_total{app_type=~\"$app_type\", instance=~\"$instance\"}",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 21 },
      "id": 6,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Current Queue Size",
      "targets": [
        {
          "expr": "lurkarr_arr_queue_total{app_type=~\"$app_type\", instance=~\"$instance\"}",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "Disk Space",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "green", "value": 0.2 }] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 27 },
      "id": 7,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Disk Free %",
      "targets": [
        {
          "expr": "lurkarr_arr_disk_free_bytes{app_type=~\"$app_type\", instance=~\"$instance\"} / lurkarr_arr_disk_total_bytes{app_type=~\"$app_type\", instance=~\"$instance\"}",
          "legendFormat": "{{app_type}} / {{instance}} — {{path}}"
        }
      ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Free Disk Space Over Time",
      "targets": [
        {
          "expr": "lurkarr_arr_disk_free_bytes{app_type=~\"$app_type\", instance=~\"$instance\"}",
          "legendFormat": "{{app_type}} / {{instance}} — {{path}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 9,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Total Disk Space Over Time",
      "targets": [
        {
          "expr": "lurkarr_arr_disk_total_bytes{app_type=~\"$app_type\", instance=~\"$instance\"}",
          "legendFormat": "{{app_type}} / {{instance}} — {{path}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 103,
      "title": "Lurking Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Lurk Searches (rate)",
      "targets": [
        {
          "expr": "rate(lurkarr_lurk_searches_total{app_type=~\"$app_type\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Missing + Upgrades Found (rate)",
      "targets": [
        {
          "expr": "rate(lurkarr_lurk_missing_found_total{app_type=~\"$app_type\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "missing: {{app_type}} / {{instance}}"
        },
        {
          "expr": "rate(lurkarr_lurk_upgrades_found_total{app_type=~\"$app_type\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "upgrades: {{app_type}} / {{instance}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Lurk Duration (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(lurkarr_lurk_duration_seconds_bucket{app_type=~\"$app_type\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Lurk Errors (rate)",
      "targets": [
        {
          "expr": "rate(lurkarr_lurk_errors_total{app_type=~\"$app_type\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{app_type}} / {{instance}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "id": 104,
      "title": "Queue Cleaner",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
