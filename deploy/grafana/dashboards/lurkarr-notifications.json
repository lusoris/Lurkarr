{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview", "url": "/d/lurkarr-overview", "type": "link", "icon": "apps" },
    { "title": "System", "url": "/d/lurkarr-system", "type": "link", "icon": "cog" },
    { "title": "Logs", "url": "/d/lurkarr-logs", "type": "link", "icon": "document-info" }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Sent",
      "targets": [
        { "expr": "sum(lurkarr_notifications_sent_total{provider=~\"$provider\"})", "legendFormat": "" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Errors",
      "targets": [
        { "expr": "sum(lurkarr_notifications_errors_total{provider=~\"$provider\"})", "legendFormat": "" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Error Rate",
      "targets": [
        { "expr": "sum(rate(lurkarr_notifications_errors_total{provider=~\"$provider\"}[$__rate_interval])) / (sum(rate(lurkarr_notifications_sent_total{provider=~\"$provider\"}[$__rate_interval])) + sum(rate(lurkarr_notifications_errors_total{provider=~\"$provider\"}[$__rate_interval])) + 1e-10)", "legendFormat": "" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg Delivery Time",
      "targets": [
        { "expr": "sum(rate(lurkarr_notifications_duration_seconds_sum{provider=~\"$provider\"}[$__rate_interval])) / sum(rate(lurkarr_notifications_duration_seconds_count{provider=~\"$provider\"}[$__rate_interval]))", "legendFormat": "" }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "Send Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] } },
      "title": "Notifications Sent / sec — by Provider",
      "targets": [
        { "expr": "sum by (provider) (rate(lurkarr_notifications_sent_total{provider=~\"$provider\"}[$__rate_interval]))", "legendFormat": "{{ provider }}" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] } },
      "title": "Notifications Sent / sec — by Event Type",
      "targets": [
        { "expr": "sum by (event_type) (rate(lurkarr_notifications_sent_total{provider=~\"$provider\"}[$__rate_interval]))", "legendFormat": "{{ event_type }}" }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "drawStyle": "bars" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "title": "Errors / sec — by Provider",
      "targets": [
        { "expr": "sum by (provider) (rate(lurkarr_notifications_errors_total{provider=~\"$provider\"}[$__rate_interval]))", "legendFormat": "{{ provider }}" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "drawStyle": "bars" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "title": "Errors / sec — by Event Type",
      "targets": [
        { "expr": "sum by (event_type) (rate(lurkarr_notifications_errors_total{provider=~\"$provider\"}[$__rate_interval]))", "legendFormat": "{{ event_type }}" }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "title": "Delivery Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "title": "Delivery Duration p50 / p95 / p99",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(lurkarr_notifications_duration_seconds_bucket{provider=~\"$provider\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(lurkarr_notifications_duration_seconds_bucket{provider=~\"$provider\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(lurkarr_notifications_duration_seconds_bucket{provider=~\"$provider\"}[$__rate_interval])))", "legendFormat": "p99" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "title": "Delivery Duration p95 — by Provider",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(lurkarr_notifications_duration_seconds_bucket{provider=~\"$provider\"}[$__rate_interval])))", "legendFormat": "{{ provider }}" }
      ],
      "type": "timeseries"
    }
  ],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(lurkarr_notifications_sent_total, provider)",
        "hide": 0,
        "includeAll": true,
        "label": "Provider",
        "multi": true,
        "name": "provider",
        "query": { "query": "label_values(lurkarr_notifications_sent_total, provider)" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Lurkarr Notifications",
  "uid": "lurkarr-notifications",
  "version": 1
}
